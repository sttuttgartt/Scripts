          <stringProp name="script">import org.apache.commons.lang3.RandomStringUtils
import java.util.UUID
import java.util.Random
import java.util.concurrent.ThreadLocalRandom


// Функция для генерации случайного UUID
def generateMsgId() {
    return UUID.randomUUID().toString()
}

// Функция для генерации случайного ИНН ФЛ
def generateInnFl() {
	def long min = 00000000000L
def long max = 230000000000L
 def rand = new Random()
  def long inn = ThreadLocalRandom.current().nextLong(min, max + 1)
    return String.valueOf(inn)

// nextLong(origin, bound) - генерирует от origin (вкл) до bound (искл)
// Чтобы включить max, мы передаем max + 1


//println &quot;Случайное число типа Long: ${randomLong}&quot;

    
}

// Данные для генерации ФИО
def femaleNames = [&apos;Александра&apos;, &apos;Елена&apos;, &apos;Ольга&apos;, &apos;Ирина&apos;, &apos;Наталья&apos;]
def maleNames = [&apos;Александр&apos;, &apos;Василий&apos;, &apos;Петр&apos;, &apos;Иван&apos;, &apos;Дмитрий&apos;]
def lastNames = [&apos;Смирнов&apos;, &apos;Иванов&apos;, &apos;Кузнецов&apos;, &apos;Соколов&apos;, &apos;Попов&apos;]
def middleNamesMale = [&apos;Алексеевич&apos;, &apos;Петрович&apos;, &apos;Иванович&apos;, &apos;Дмитриевич&apos;, &apos;Андреевич&apos;]
def middleNamesFemale = [&apos;Алексеевна&apos;, &apos;Петровна&apos;, &apos;Ивановна&apos;, &apos;Дмитриевна&apos;, &apos;Андреевна&apos;]

// Функция для выбора случайного элемента из списка
def getRandomElement(list) {
   def rand = new Random()
    return list[rand.nextInt(list.size())]
}

// Выбор пола (0 - женский, 1 - мужской)
def gender = new Random().nextInt(2)

// Генерация ФИО
def name = gender == 0 ? getRandomElement(femaleNames) : getRandomElement(maleNames)
def lastName = getRandomElement(lastNames) + (gender == 0 ? &apos;а&apos; : &apos;&apos;)
def middleName = gender == 0 ? getRandomElement(middleNamesFemale) : getRandomElement(middleNamesMale)
def fullName = lastName + &quot; &quot; + name + &quot; &quot; + middleName

// Создание JSON-сообщения
def msgId = generateMsgId()
def inn = generateInnFl()

def message = [
    msg_id: msgId,
    full_name: fullName,
    inn: inn
]

// Преобразование в JSON-строку
def jsonMessage = new groovy.json.JsonBuilder(message).toString()

// Сохранение в переменные JMeter
vars.put(&quot;jsonMessage&quot;, jsonMessage)</stringProp>
        </JSR223Sampler>
